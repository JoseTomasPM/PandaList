@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Identity
@inject NavigationManager Nav

@inherits LayoutComponentBase
<link href="~/app.css" rel="stylesheet" />
<div class="page">
    <div class="sidebar">
        <NavMenu />
    </div>


    <main>
        <div class="top-row px-4 auth-bar">

            <AuthorizeView>
                <Authorized>
                    <span class="user-name">
                        Hiii @context.User.Identity?.Name
                    </span>
                    <a href="/Identity/Account/Logout" class="btn btn-sm btn-ghost">
                        Logout
                    </a>
                </Authorized>

                <NotAuthorized>
                    <a href="/Identity/Account/Login" class="btn btn-sm btn-ghost">
                        Login
                    </a>
                    <a href="/Identity/Account/Register" class="btn btn-sm btn-primary">
                        Register
                    </a>
                </NotAuthorized>
            </AuthorizeView>

        </div>

        <article class="content px-4">
            @Body
        </article>
    </main>
</div>

<div id="blazor-error-ui">
    An unhandled error has occurred.
    <a href="" class="reload">Reload</a>
    <a class="dismiss">🗙</a>
</div>



@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Identity
@inject NavigationManager Nav

@inherits LayoutComponentBase

<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css" rel="stylesheet">
<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="">PandaList</a>       
    </div>    
</div>

<input type="checkbox" title="Navigation menu" class="navbar-toggler" />

<div class="nav-scrollable" onclick="document.querySelector('.navbar-toggler').click()">
    <nav class="flex-column">

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="books">
                <span class="bi bi-book" aria-hidden="true"></span> Books
            </NavLink>
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="series">
                <span class="bi bi-camera-reels" aria-hidden="true"></span> Series
            </NavLink>
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="films">
                <span class="bi bi-film" aria-hidden="true"></span> Films
            </NavLink>
        </div>


    </nav>
</div>


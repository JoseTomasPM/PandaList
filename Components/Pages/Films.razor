@page "/films"
@attribute [Authorize]

@using PandaList.Models
@using PandaList.Data
@using Microsoft.EntityFrameworkCore
@using Microsoft.AspNetCore.Components.Authorization

@inject AppDbContext Db
@inject AuthenticationStateProvider AuthStateProvider
@inject IJSRuntime JS

<h3 class="page-title">My Films (@films.Count)</h3>

@if (isLoading)
{
    <p>Loading...</p>
}
else
{
    <button class="btn btn-primary" @onclick="OpenModal">Add New Film</button>

    <div class="table-container">

        @if (!films.Any())
        {
            <p>No films yet.</p>
        }
        else
        {
            <div class="films-grid">

                @foreach (var film in films)
                {
                    <div class="films-card">

                        <div class="film-content">
                            <h5 class="title">@film.Title</h5>
                            <p class="author">@film.Director</p>
                            <span class="status">
                                @(film.Watched ? "✔ Watched" : "🎬 To Watch")
                            </span>
                        </div>

                        <div class="film-footer">

                            <div class="actions">

                                <button class="btn btn-sm btn-outline-success"
                                        @onclick="() => ToggleWatched(film)">
                                    <i class="bi bi-check"></i>
                                </button>

                                <button class="btn btn-sm btn-outline-primary"
                                        @onclick="() => EditFilm(film)">
                                    <i class="bi bi-pencil"></i>
                                </button>

                                <button class="btn btn-sm btn-outline-danger"
                                        @onclick="() => Delete(film.Id)">
                                    <i class="bi bi-trash"></i>
                                </button>

                            </div>

                        </div>

                    </div>
                }

            </div>
        }

    </div>
}

@if (showModal)
{
    <div class="modal-backdrop-custom"></div>
    <div class="modal fade show d-block">

        <div class="modal-dialog">
            <div class="modal-content">

                <div class="modal-body">

                    <EditForm Model="newFilm" OnValidSubmit="Save">

                        <DataAnnotationsValidator />

                        <div class="mb-3">
                            <label>Title</label>
                            <InputText class="form-control" @bind-Value="newFilm.Title" />
                        </div>

                        <div class="mb-3">
                            <label>Director</label>
                            <InputText class="form-control" @bind-Value="newFilm.Director" />
                        </div>

                        <div class="mb-3">
                            <label>Year</label>
                            <InputNumber class="form-control" @bind-Value="newFilm.Year" />
                        </div>

                        <div class="form-check mb-3">
                            <InputCheckbox class="form-check-input" @bind-Value="newFilm.Watched" />
                            <label class="form-check-label">Watched</label>
                        </div>

                        <button class="btn btn-primary" type="submit">Save</button>

                    </EditForm>

                </div>

                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="CloseModal">Close</button>
                </div>

            </div>
        </div>

    </div>
}

@code {

    private List<Film> films = new();
    private Film newFilm = new();
    private bool isLoading = true;
    private bool showModal = false;

    private bool isEditing = false;
    private int editingId;

    private string userId = "";

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        userId = user.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)!.Value;

        films = await Db.Films
            .Where(f => f.UserId == userId)
            .ToListAsync();

        isLoading = false;
    }

    void OpenModal()
    {
        newFilm = new Film { Watched = false };
        showModal = true;
    }

    void CloseModal() => showModal = false;

    async Task Save()
    {
        if (isEditing)
        {
            var film = await Db.Films.FindAsync(editingId);

            if (film != null)
            {
                film.Title = newFilm.Title;
                film.Director = newFilm.Director;
                film.Year = newFilm.Year;
                film.Watched = newFilm.Watched;

                await Db.SaveChangesAsync();
            }
        }
        else
        {
            newFilm.UserId = userId;
            Db.Films.Add(newFilm);
            await Db.SaveChangesAsync();
            films.Add(newFilm);
        }

        isEditing = false;
        showModal = false;
    }

    async Task Delete(int id)
    {
        var confirm = await JS.InvokeAsync<bool>("confirm", "Delete this film?");

        if (!confirm) return;

        var film = await Db.Films.FindAsync(id);

        if (film != null)
        {
            Db.Films.Remove(film);
            await Db.SaveChangesAsync();
            films.Remove(film);
        }
    }

    void EditFilm(Film film)
    {
        isEditing = true;
        editingId = film.Id;

        newFilm = new Film
            {
                Id = film.Id,
                Title = film.Title,
                Director = film.Director,
                Year = film.Year,
                Watched = film.Watched
            };

        showModal = true;
    }

    async Task ToggleWatched(Film film)
    {
        film.Watched = !film.Watched;
        Db.Films.Update(film);
        await Db.SaveChangesAsync();
    }

}
@page "/series"
@attribute [Authorize]

@using PandaList.Models
@using PandaList.Data
@using Microsoft.EntityFrameworkCore
@using Microsoft.AspNetCore.Components.Authorization
@inject AppDbContext Db
@inject AuthenticationStateProvider AuthStateProvider
@inject IJSRuntime JS

<h3 class="page-title">My Series (@series.Count)</h3>

@if (isLoading)
{
    <p>Loading...</p>
}
else
{
    <button class="btn btn-primary" @onclick="OpenModal">Add New Series</button>

    <div class="table-container">

        @if (!series.Any())
        {
            <p class="empty-state">No series yet.</p>
        }
        else
        {
            <div class="series-grid">

                @foreach (var s in series)
                {
                    <div class="series-card">

                        <div class="series-content">
                            <h5 class="title">@s.Title</h5>
                            <p class="author">Seasons: @s.Seasons</p>
                            <span class="status">
                                @(s.Finished ? "✔ Finished" : "📺 Watching")
                            </span>
                        </div>

                        <div class="series-footer">
                            <div class="actions">

                                <button class="btn btn-sm btn-outline-success"
                                        @onclick="() => ToggleFinished(s)"
                                        title="Toggle finished">
                                    <i class="bi bi-check"></i>
                                </button>

                                <button class="btn btn-sm btn-outline-primary"
                                        @onclick="() => EditSeries(s)"
                                        title="Edit series">
                                    <i class="bi bi-pencil"></i>
                                </button>

                                <button class="btn btn-sm btn-outline-danger"
                                        @onclick="() => Delete(s.Id)"
                                        title="Delete series">
                                    <i class="bi bi-trash"></i>
                                </button>

                            </div>
                        </div>

                    </div>
                }

            </div>
        }

    </div>
}

@if (showModal)
{
    <div class="modal-backdrop-custom"></div>
    <div class="modal fade show d-block">
        <div class="modal-dialog">
            <div class="modal-content">

                <div class="modal-body">
                    <EditForm Model="newSeries" OnValidSubmit="Save">
                        <DataAnnotationsValidator />
                        <ValidationSummary />

                        <div class="mb-3">
                            <label>Title</label>
                            <InputText class="form-control" @bind-Value="newSeries.Title" />
                        </div>

                        <div class="mb-3">
                            <label>Seasons</label>
                            <InputNumber class="form-control" @bind-Value="newSeries.Seasons" />
                        </div>

                        <div class="form-check mb-3">
                            <InputCheckbox class="form-check-input" @bind-Value="newSeries.Finished" />
                            <label class="form-check-label">Finished</label>
                        </div>

                        <button type="submit" class="btn btn-primary">Save</button>
                    </EditForm>
                </div>

                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="CloseModal">Close</button>
                </div>

            </div>
        </div>
    </div>
}

@code {
    private List<Series> series = new();
    private Series newSeries = new();
    private bool isLoading = true;
    private bool showModal = false;
    private string userId = "";

    private bool isEditing = false;
    private int editingId;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        userId = user.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)!.Value;

        series = await Db.Series
            .Where(s => s.UserId == userId)
            .ToListAsync();

        isLoading = false;
    }

    void OpenModal()
    {
        newSeries = new Series { Seasons = 1, Finished = false };
        showModal = true;
    }

    void CloseModal() => showModal = false;

    async Task Save()
    {
        if (isEditing)
        {
            var s = await Db.Series.FindAsync(editingId);
            if (s != null && s.UserId == userId)
            {
                s.Title = newSeries.Title;
                s.Seasons = newSeries.Seasons;
                s.Finished = newSeries.Finished;

                await Db.SaveChangesAsync();

                var index = series.FindIndex(x => x.Id == editingId);
                if (index != -1) series[index] = s;
            }
        }
        else
        {
            newSeries.UserId = userId;
            Db.Series.Add(newSeries);
            await Db.SaveChangesAsync();
            series.Add(newSeries);
        }

        isEditing = false;
        showModal = false;
    }

    async Task Delete(int id)
    {
        var confirm = await JS.InvokeAsync<bool>("confirm", "Delete this series?");
        if (!confirm) return;

        var s = await Db.Series.FindAsync(id);
        if (s != null && s.UserId == userId)
        {
            Db.Series.Remove(s);
            await Db.SaveChangesAsync();
            series.Remove(s);
        }
    }

    void EditSeries(Series s)
    {
        isEditing = true;
        editingId = s.Id;

        newSeries = new Series
            {
                Id = s.Id,
                Title = s.Title,
                Seasons = s.Seasons,
                Finished = s.Finished,
                UserId = s.UserId
            };

        showModal = true;
    }

    async Task ToggleFinished(Series s)
    {
        s.Finished = !s.Finished;
        Db.Series.Update(s);
        await Db.SaveChangesAsync();
    }
}
@page "/books"
@page "/"
@attribute [Authorize]


@using PandaList.Models
@using PandaList.Data
@using Microsoft.AspNetCore.Authorization
@using Microsoft.EntityFrameworkCore

@inject IHttpContextAccessor HttpContextAccessor
@inject AppDbContext Db
@inject IJSRuntime JS

<h3 class="page-title">My Books (@books.Count)</h3>

@if (isLoading)
{
    <p>Loading...</p>
}
else
{
    <button class="btn btn-secondary mb-3" @onclick="OpenModal">Add New Book</button>

    <div class="table-container">

        @if (!books.Any())
        {
            <p>No books yet.</p>
        }
        else
        {
            <div class="books-grid">

                @foreach (var book in books)
                {
                    <div class="book-card">

                        <div class="book-content">
                            <h5 class="title">@book.Title</h5>
                            <p class="author">@book.Author</p>
                            <span class="status">
                                @(book.Finished ? "✔ Finished" : "📖 Reading")
                            </span>
                        </div>

                        <div class="book-footer">
                                                       
                            <div class="actions">

                                <button class="btn btn-sm btn-success"
                                        title="Toggle status"
                                        @onclick="() => ToggleFinished(book)">
                                    <i class="bi bi-check"></i>
                                </button>

                                <button class="btn btn-sm btn-light"
                                        title="Edit"
                                        @onclick="() => EditBook(book)">
                                    <i class="bi bi-pencil"></i>
                                </button>

                                <button class="btn btn-sm btn-danger"
                                        title="Delete book"
                                        @onclick="() => Delete(book.Id)">
                                    <i class="bi bi-trash"></i>
                                </button>

                            </div>
                                                           

                        </div>

                    </div>
                }

            </div>
        }

    </div>
}

@if (showModal)
{
    <div class="modal-backdrop-custom"></div>
    <div class="modal fade show d-block" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                
                <div class="modal-body">
                    <EditForm Model="newBook" OnValidSubmit="Save">
                        <DataAnnotationsValidator />
                        <ValidationSummary />

                        <div class="mb-3">
                            <label class="form-label">Title</label>
                            <InputText class="form-control" @bind-Value="newBook.Title" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Author</label>
                            <InputText class="form-control" @bind-Value="newBook.Author" />
                        </div>

                        <div class="form-check mb-3">
                            <InputCheckbox class="form-check-input" @bind-Value="newBook.Finished" />
                            <label class="form-check-label">
                                Finished
                            </label>
                        </div>

                        <div class="modal-footer">
                            <button class="btn btn-light" type="submit">Save</button>
                            <button class="btn btn-secondary" @onclick="CloseModal">Close</button>
                        </div>
                        

                    </EditForm>
                </div>

            </div>
        </div>
    </div>
}

@code {
    private List<Book> books = new();
    private bool isLoading = true;
    private bool showModal = false;
    private Book newBook = new();
    private string userId = "";
    private bool isEditing = false;
    private int editingId;

    protected override async Task OnInitializedAsync()
    {
        var user = HttpContextAccessor.HttpContext?.User;

        if (user == null)
            return; 

        userId = user.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value!;

        books = await Db.Books
            .Where(b => b.UserId == userId)
            .ToListAsync();

        isLoading = false;
    }


    private void OpenModal()
    {
        newBook = new Book
            {
                Title = "",
                Author = "",
                UserId = userId,
                Finished = false
            };

        showModal = true;
    }

    private void CloseModal() => showModal = false;

    async Task Save()
    {
        if (string.IsNullOrEmpty(userId))
            return;

        if (isEditing)
        {
            var book = await Db.Books.FindAsync(editingId);

            if (book != null && book.UserId == userId)
            {
                book.Title = newBook.Title;
                book.Author = newBook.Author;
                book.Finished = newBook.Finished;

                await Db.SaveChangesAsync();

                var index = books.FindIndex(b => b.Id == editingId);
                if (index != -1)
                    books[index] = book;
            }
        }
        else
        {
            newBook.UserId = userId;

            Db.Books.Add(newBook);
            await Db.SaveChangesAsync();

            books.Add(newBook);
        }

        isEditing = false;
        showModal = false;
    }


    async Task Delete(int id)
    {
        var confirm = await JS.InvokeAsync<bool>("confirm", "Delete this book?");

        if (!confirm)
            return;

        var libro = await Db.Books.FindAsync(id);

        if (libro != null && libro.UserId == userId)
        {
            Db.Books.Remove(libro);
            await Db.SaveChangesAsync();

            books.Remove(libro);
        }
    }

    void EditBook(Book book)
    {
        isEditing = true;
        editingId = book.Id;

        newBook = new Book
            {
                Id = book.Id,
                Title = book.Title,
                Author = book.Author,
                UserId = book.UserId,
                Finished = book.Finished
            };

        showModal = true;
    }
    async Task ToggleFinished(Book book)
    {
        book.Finished = !book.Finished;

        Db.Books.Update(book);
        await Db.SaveChangesAsync();
    }
}
